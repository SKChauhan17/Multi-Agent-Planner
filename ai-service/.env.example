# -----------------------------------------------------------------------------
# AI Provider Credentials (Required)
# -----------------------------------------------------------------------------
GROQ_API_KEY=gsk_your_groq_key_here
OPENROUTER_API_KEY=sk-or-v1_your_openrouter_key_here

# -----------------------------------------------------------------------------
# OpenRouter Request Metadata (Optional)
# -----------------------------------------------------------------------------
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=multi-agent-planner

# -----------------------------------------------------------------------------
# Service Connectivity & Security
# -----------------------------------------------------------------------------
# Comma-separated allowed browser origins for CORS
ALLOWED_ORIGINS=http://localhost:3000

# Internal Task API base URL (no trailing slash)
TASK_API_BASE_URL=http://localhost:4000

# Shared token used when calling Task API (set in production)
TASK_API_INTERNAL_TOKEN=

# Timeout for Task API calls (seconds)
TASK_API_TIMEOUT_SECONDS=30

# Per-IP + endpoint in-memory rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=90
