# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=4000

# -----------------------------------------------------------------------------
# SQLite Database
# -----------------------------------------------------------------------------
DB_PATH=./data/planner.db

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
# Comma-separated CORS allowlist for browser origins
ALLOWED_ORIGINS=http://localhost:3000

# Shared token expected from trusted callers (required in production)
INTERNAL_API_TOKEN=

# JSON request body size limit
JSON_BODY_LIMIT=200kb

# In-memory per-IP rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
